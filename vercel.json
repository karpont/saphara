{
  "version": 2,
  "installCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @saphara/web... build",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://saphara-api.onrender.com/api/$1" }
  ]
}
