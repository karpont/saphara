{
  "name": "saphara",
  "version": "0.1.0",
  "private": true,
  "description": "Saphara - Crypto destekli sosyal ag platformu (sosyal feed + Reels + market + cuzdan)",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "e2e"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "contracts:compile": "pnpm --filter @saphara/contracts compile",
    "contracts:test": "pnpm --filter @saphara/contracts test",
    "setup": "bash scripts/setup.sh",
    "db:up": "docker compose up -d db",
    "db:migrate": "pnpm --filter @saphara/api prisma migrate dev",
    "db:seed": "pnpm --filter @saphara/api prisma:seed",
    "check": "bash scripts/check.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.5",
    "@types/node": "^20.12.0",
    "next": "^14.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}