# ---- Saphara ortam degiskenleri (ornek) ----
# Kullanici tarafindan doldurulacak kritik degerler:
NEXT_PUBLIC_PART_TOKEN_ADDRESS=0xD95aC89029451c57Adf172192176d7264d49305a
NEXT_PUBLIC_TREASURY_ADDRESS=0x55B26f8CD67632d7AF9a888c645054Ca76E53455
NEXT_PUBLIC_TIPPING_ADDRESS=0x...
NEXT_PUBLIC_MARKET_ADDRESS=0x...

# Zincir / cuzdan
NEXT_PUBLIC_RPC_URL_BSC=https://bsc-dataseed.bnbchain.org
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=     # cloud.walletconnect.com'dan alinir
NEXT_PUBLIC_PLATFORM_FEE_BPS=250          # %2.5

# Deploy (sadece sozlesme yuklerken)
DEPLOYER_PRIVATE_KEY=
TREASURY_ADDRESS=0x55B26f8CD67632d7AF9a888c645054Ca76E53455
PART_INITIAL_SUPPLY=1000000000
BSCSCAN_API_KEY=

# Backend
DATABASE_URL=postgresql://user:pass@localhost:5432/saphara
S3_ENDPOINT=
S3_BUCKET=saphara-media
TURNSTILE_SECRET=

# Haber API anahtarlari (ucretsiz: gnews.io / newsdata.io)
GNEWS_API_KEY=
NEWSDATA_API_KEY=

# Production CORS (virgulle ayrilmis domainler; bos birakirsa acik)
